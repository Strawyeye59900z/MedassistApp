rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        ("email" in request.auth.token && request.auth.token.email == "gabriel.nunez.costa@gmail.com") ||
        (exists(/databases/$(database)/documents/users_registered/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users_registered/$(request.auth.uid)).data.email == "gabriel.nunez.costa@gmail.com")
      );
    }

    function isOwnerOrAdmin(userId) {
      return isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Presets collection (Public read, Admin write)
    match /presets/{presetId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Registered Users Directory (for Admin & self check)
    match /users_registered/{userId} {
      allow create: if isSignedIn();
      allow get: if isOwnerOrAdmin(userId);
      allow list, update, delete: if isAdmin();
    }

    // User settings and data
    match /users/{userId} {
      allow get, create, update, delete: if isOwnerOrAdmin(userId);

      // Recursive match for all sub-collections of user
      match /{allSubcollections=**} {
        allow read, write: if isOwnerOrAdmin(userId);
      }
    }
  }
}
